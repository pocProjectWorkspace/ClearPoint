# Database — PostgreSQL (Railway provides this automatically)
DATABASE_URL="postgresql://user:password@host:5432/clearpoint?sslmode=require"

# For local dev with SQLite:
# 1. Change prisma/schema.prisma provider to "sqlite"
# 2. Set: DATABASE_URL="file:./dev.db"

# Authentication
JWT_SECRET="change-this-in-production"
CONSULTANT_EMAIL="consultant@mindssparc.com"
CONSULTANT_PASSWORD="change-this"
CONSULTANT_NAME="Consultant"

# AI Narrative Generation (optional — structured fallback used if not set)
ANTHROPIC_API_KEY=""

# Server
PORT=3001
VITE_APP_URL="https://your-app.vercel.app"
NODE_ENV="production"
