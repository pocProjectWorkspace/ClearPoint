{
  "buildCommand": "cd ../.. && pnpm --filter @mindssparc/shared-types build && pnpm --filter @mindssparc/web build",
  "outputDirectory": "dist",
  "installCommand": "cd ../.. && pnpm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
